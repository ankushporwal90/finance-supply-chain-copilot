# Required for AI responses.
# Create a free key from Groq and paste it into your local .env file.
GROQ_API_KEY=your_groq_api_key_here

# Default Groq model. Keep this configurable because model availability changes over time.
GROQ_MODEL=llama-3.1-8b-instant

# Free local embedding model from sentence-transformers.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Local persistence paths.
CHROMA_PERSIST_DIR=data/vector_store
SQLITE_DB_PATH=data/sqlite/copilot.db

# SEC EDGAR asks apps to identify themselves with contact info.
# Example: Your Name your.email@example.com
SEC_USER_AGENT=FinanceSupplyChainCopilot your.email@example.com

# App behavior.
APP_ENV=development
LOG_LEVEL=INFO
